# ================================================================
# Little League Manager — Agent configuration
# ================================================================
# Copy this file to `.env` and fill in the values for your provider.

# Pick one: "watsonx" | "custom" | "mock"
LLM_PROVIDER=mock

# IBM watsonx.ai — fill these to use IBM Cloud foundation models.
WATSONX_APIKEY=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# OpenAI-compatible / open-source endpoint (vLLM, Ollama, LM Studio, …).
CUSTOM_LLM_BASE_URL=http://localhost:8080/v1
CUSTOM_LLM_API_KEY=not-needed
CUSTOM_LLM_MODEL=llama-3.1-8b-instruct

# Optional: pin "today" so demos are reproducible. Leave empty for real wall-clock.
# Format: YYYY-MM-DD. The provided dataset spans 2026-01-15 .. 2026-05-05.
DEMO_TODAY=2026-04-25

# Where the CSV data lives (relative to repo root).
DATA_DIR=data

# ----------------------------------------------------------------------
# Weather provider
# ----------------------------------------------------------------------
# Pick one: "openweather" | "open-meteo" | "mock"
#   - openweather: OpenWeatherMap 5-day/3-hour forecast. Free key needed.
#                  Sign up: https://home.openweathermap.org/users/sign_in
#   - open-meteo:  Open-Meteo daily forecast. NO API key, 16-day horizon.
#                  https://open-meteo.com/  — recommended for longer planning.
#   - mock:        Deterministic seeded fallback (always works, no network).
WEATHER_PROVIDER=mock

OPENWEATHER_API_KEY=

# Default league location (overridable from the UI).
LEAGUE_CITY=Austin, US
LEAGUE_LAT=30.27
LEAGUE_LON=-97.74
